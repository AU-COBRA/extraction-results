import Basics exposing (..)
import Blockchain exposing (..)
import Bool exposing (..)
import Int exposing (..)
import Maybe exposing (..)
import Order exposing (..)
import Transaction exposing (..)
import Tuple exposing (..)

-- some dummy definitions (will be remapped properly in the future)
type AccountAddress = Int
type ConCertAction = Act_transfer Int Z
type ConCertCallContext = CCtx Unit
type ConCertChain = CChain Unit
ctx_from ctx = 0
ctx_contract_address _ = 0
ctx_contract_balance _ = (Zpos (XO XH))
ctx_amount ctx = (Zpos (XO XH))
current_slot _ = O


type Positive
  = XI Positive
  | XO Positive
  | XH

type Option a
  = Some a
  | None

type Unit
  = Tt

type Z
  = Z0
  | Zpos Positive
  | Zneg Positive

type Prod a b
  = Pair a b

type List a
  = Nil
  | Cons a (List a)

type Nat
  = O
  | S Nat

type NextStep
  = Buyer_commit
  | Buyer_confirm
  | Withdrawals
  | No_next_step

type State
  = Build_state Nat NextStep Int Int Z Z

type Msg
  = Commit_money
  | Confirm_item_received
  | Withdraw

type Result t e
  = Ok t
  | Err e

type alias Error = Nat

conCert_Examples_Escrow_Escrow_next_step : State -> NextStep
conCert_Examples_Escrow_Escrow_next_step s =
  case s of
    Build_state last_action next_step seller buyer seller_withdrawable buyer_withdrawable ->
      next_step

type Monad m
  = Build_monad (() -> () -> m) (() -> () -> m -> (() -> m) -> m)

conCert_Execution_Monad_bind : Monad () -> () -> () -> m -> (t -> m) -> m
conCert_Execution_Monad_bind monad =
  case monad of
    Build_monad ret bind ->
      bind

conCert_Execution_ResultMonad_result_of_option : Option t -> e -> Result t e
conCert_Execution_ResultMonad_result_of_option o err =
  case o of
    Some a ->
      Ok a
    None ->
      Err err

type Comparison
  = Eq
  | Lt
  | Gt

corelib_BinNums_PosDef_Pos_compare_cont : Comparison -> Positive -> Positive -> Comparison
corelib_BinNums_PosDef_Pos_compare_cont r x y =
  case x of
    XI p ->
      case y of
        XI q ->
          corelib_BinNums_PosDef_Pos_compare_cont r p q
        XO q ->
          corelib_BinNums_PosDef_Pos_compare_cont Gt p q
        XH ->
          Gt
    XO p ->
      case y of
        XI q ->
          corelib_BinNums_PosDef_Pos_compare_cont Lt p q
        XO q ->
          corelib_BinNums_PosDef_Pos_compare_cont r p q
        XH ->
          Gt
    XH ->
      case y of
        XI q ->
          Lt
        XO q ->
          Lt
        XH ->
          r

corelib_BinNums_PosDef_Pos_compare : Positive -> Positive -> Comparison
corelib_BinNums_PosDef_Pos_compare =
  corelib_BinNums_PosDef_Pos_compare_cont Eq

corelib_Init_Datatypes_CompOpp : Comparison -> Comparison
corelib_Init_Datatypes_CompOpp r =
  case r of
    Eq ->
      Eq
    Lt ->
      Gt
    Gt ->
      Lt

corelib_BinNums_IntDef_Z_compare : Z -> Z -> Comparison
corelib_BinNums_IntDef_Z_compare x y =
  case x of
    Z0 ->
      case y of
        Z0 ->
          Eq
        Zpos y2 ->
          Lt
        Zneg y2 ->
          Gt
    Zpos x2 ->
      case y of
        Z0 ->
          Gt
        Zpos y2 ->
          corelib_BinNums_PosDef_Pos_compare x2 y2
        Zneg y2 ->
          Gt
    Zneg x2 ->
      case y of
        Z0 ->
          Lt
        Zpos y2 ->
          Lt
        Zneg y2 ->
          corelib_Init_Datatypes_CompOpp (corelib_BinNums_PosDef_Pos_compare x2 y2)

corelib_BinNums_IntDef_Z_ltb : Z -> Z -> Bool
corelib_BinNums_IntDef_Z_ltb x y =
  case corelib_BinNums_IntDef_Z_compare x y of
    Eq ->
      False
    Lt ->
      True
    Gt ->
      False

corelib_BinNums_PosDef_Pos_succ : Positive -> Positive
corelib_BinNums_PosDef_Pos_succ x =
  case x of
    XI p ->
      XO (corelib_BinNums_PosDef_Pos_succ p)
    XO p ->
      XI p
    XH ->
      XO XH

corelib_BinNums_PosDef_Pos_add : Positive -> Positive -> Positive
corelib_BinNums_PosDef_Pos_add =
  let
    add x y =
      case x of
        XI p ->
          case y of
            XI q ->
              XO (add_carry p q)
            XO q ->
              XI (add p q)
            XH ->
              XO (corelib_BinNums_PosDef_Pos_succ p)
        XO p ->
          case y of
            XI q ->
              XI (add p q)
            XO q ->
              XO (add p q)
            XH ->
              XI p
        XH ->
          case y of
            XI q ->
              XO (corelib_BinNums_PosDef_Pos_succ q)
            XO q ->
              XI q
            XH ->
              XO XH
    add_carry x y =
      case x of
        XI p ->
          case y of
            XI q ->
              XI (add_carry p q)
            XO q ->
              XO (add_carry p q)
            XH ->
              XI (corelib_BinNums_PosDef_Pos_succ p)
        XO p ->
          case y of
            XI q ->
              XO (add_carry p q)
            XO q ->
              XI (add p q)
            XH ->
              XO (corelib_BinNums_PosDef_Pos_succ p)
        XH ->
          case y of
            XI q ->
              XI (corelib_BinNums_PosDef_Pos_succ q)
            XO q ->
              XO (corelib_BinNums_PosDef_Pos_succ q)
            XH ->
              XI XH
  in
  add

corelib_BinNums_IntDef_Z_double : Z -> Z
corelib_BinNums_IntDef_Z_double x =
  case x of
    Z0 ->
      Z0
    Zpos p ->
      Zpos (XO p)
    Zneg p ->
      Zneg (XO p)

corelib_BinNums_PosDef_Pos_pred_double : Positive -> Positive
corelib_BinNums_PosDef_Pos_pred_double x =
  case x of
    XI p ->
      XI (XO p)
    XO p ->
      XI (corelib_BinNums_PosDef_Pos_pred_double p)
    XH ->
      XH

corelib_BinNums_IntDef_Z_succ_double : Z -> Z
corelib_BinNums_IntDef_Z_succ_double x =
  case x of
    Z0 ->
      Zpos XH
    Zpos p ->
      Zpos (XI p)
    Zneg p ->
      Zneg (corelib_BinNums_PosDef_Pos_pred_double p)

corelib_BinNums_IntDef_Z_pred_double : Z -> Z
corelib_BinNums_IntDef_Z_pred_double x =
  case x of
    Z0 ->
      Zneg XH
    Zpos p ->
      Zpos (corelib_BinNums_PosDef_Pos_pred_double p)
    Zneg p ->
      Zneg (XI p)

corelib_BinNums_IntDef_Z_pos_sub : Positive -> Positive -> Z
corelib_BinNums_IntDef_Z_pos_sub x y =
  case x of
    XI p ->
      case y of
        XI q ->
          corelib_BinNums_IntDef_Z_double (corelib_BinNums_IntDef_Z_pos_sub p q)
        XO q ->
          corelib_BinNums_IntDef_Z_succ_double (corelib_BinNums_IntDef_Z_pos_sub p q)
        XH ->
          Zpos (XO p)
    XO p ->
      case y of
        XI q ->
          corelib_BinNums_IntDef_Z_pred_double (corelib_BinNums_IntDef_Z_pos_sub p q)
        XO q ->
          corelib_BinNums_IntDef_Z_double (corelib_BinNums_IntDef_Z_pos_sub p q)
        XH ->
          Zpos (corelib_BinNums_PosDef_Pos_pred_double p)
    XH ->
      case y of
        XI q ->
          Zneg (XO q)
        XO q ->
          Zneg (corelib_BinNums_PosDef_Pos_pred_double q)
        XH ->
          Z0

corelib_BinNums_IntDef_Z_add : Z -> Z -> Z
corelib_BinNums_IntDef_Z_add x y =
  case x of
    Z0 ->
      y
    Zpos x2 ->
      case y of
        Z0 ->
          x
        Zpos y2 ->
          Zpos (corelib_BinNums_PosDef_Pos_add x2 y2)
        Zneg y2 ->
          corelib_BinNums_IntDef_Z_pos_sub x2 y2
    Zneg x2 ->
      case y of
        Z0 ->
          x
        Zpos y2 ->
          corelib_BinNums_IntDef_Z_pos_sub y2 x2
        Zneg y2 ->
          Zneg (corelib_BinNums_PosDef_Pos_add x2 y2)

corelib_BinNums_IntDef_Z_opp : Z -> Z
corelib_BinNums_IntDef_Z_opp x =
  case x of
    Z0 ->
      Z0
    Zpos x2 ->
      Zneg x2
    Zneg x2 ->
      Zpos x2

corelib_BinNums_IntDef_Z_sub : Z -> Z -> Z
corelib_BinNums_IntDef_Z_sub m n =
  corelib_BinNums_IntDef_Z_add m (corelib_BinNums_IntDef_Z_opp n)

conCert_Examples_Escrow_Escrow_subAmountOption : Z -> Z -> Option Z
conCert_Examples_Escrow_Escrow_subAmountOption n m =
  case corelib_BinNums_IntDef_Z_ltb n m of
    True ->
      None
    False ->
      Some (corelib_BinNums_IntDef_Z_sub n m)

conCert_Examples_Escrow_Escrow_default_error : Error
conCert_Examples_Escrow_Escrow_default_error =
  S O

corelib_BinNums_PosDef_Pos_mul : Positive -> Positive -> Positive
corelib_BinNums_PosDef_Pos_mul x y =
  case x of
    XI p ->
      corelib_BinNums_PosDef_Pos_add y (XO (corelib_BinNums_PosDef_Pos_mul p y))
    XO p ->
      XO (corelib_BinNums_PosDef_Pos_mul p y)
    XH ->
      y

corelib_BinNums_IntDef_Z_mul : Z -> Z -> Z
corelib_BinNums_IntDef_Z_mul x y =
  case x of
    Z0 ->
      Z0
    Zpos x2 ->
      case y of
        Z0 ->
          Z0
        Zpos y2 ->
          Zpos (corelib_BinNums_PosDef_Pos_mul x2 y2)
        Zneg y2 ->
          Zneg (corelib_BinNums_PosDef_Pos_mul x2 y2)
    Zneg x2 ->
      case y of
        Z0 ->
          Z0
        Zpos y2 ->
          Zneg (corelib_BinNums_PosDef_Pos_mul x2 y2)
        Zneg y2 ->
          Zpos (corelib_BinNums_PosDef_Pos_mul x2 y2)

corelib_BinNums_IntDef_Z_leb : Z -> Z -> Bool
corelib_BinNums_IntDef_Z_leb x y =
  case corelib_BinNums_IntDef_Z_compare x y of
    Eq ->
      True
    Lt ->
      True
    Gt ->
      False

corelib_BinNums_IntDef_Z_pos_div_eucl : Positive -> Z -> Prod Z Z
corelib_BinNums_IntDef_Z_pos_div_eucl a b =
  case a of
    XI a2 ->
      case corelib_BinNums_IntDef_Z_pos_div_eucl a2 b of
        Pair q r ->
          let
            r2 =
              corelib_BinNums_IntDef_Z_add (corelib_BinNums_IntDef_Z_mul (Zpos (XO XH)) r) (Zpos XH)
          in
          case corelib_BinNums_IntDef_Z_ltb r2 b of
            True ->
              Pair (corelib_BinNums_IntDef_Z_mul (Zpos (XO XH)) q) r2
            False ->
              Pair (corelib_BinNums_IntDef_Z_add (corelib_BinNums_IntDef_Z_mul (Zpos (XO XH)) q) (Zpos XH)) (corelib_BinNums_IntDef_Z_sub r2 b)
    XO a2 ->
      case corelib_BinNums_IntDef_Z_pos_div_eucl a2 b of
        Pair q r ->
          let
            r2 =
              corelib_BinNums_IntDef_Z_mul (Zpos (XO XH)) r
          in
          case corelib_BinNums_IntDef_Z_ltb r2 b of
            True ->
              Pair (corelib_BinNums_IntDef_Z_mul (Zpos (XO XH)) q) r2
            False ->
              Pair (corelib_BinNums_IntDef_Z_add (corelib_BinNums_IntDef_Z_mul (Zpos (XO XH)) q) (Zpos XH)) (corelib_BinNums_IntDef_Z_sub r2 b)
    XH ->
      case corelib_BinNums_IntDef_Z_leb (Zpos (XO XH)) b of
        True ->
          Pair Z0 (Zpos XH)
        False ->
          Pair (Zpos XH) Z0

corelib_BinNums_IntDef_Z_div_eucl : Z -> Z -> Prod Z Z
corelib_BinNums_IntDef_Z_div_eucl a b =
  case a of
    Z0 ->
      Pair Z0 Z0
    Zpos a2 ->
      case b of
        Z0 ->
          Pair Z0 a
        Zpos p ->
          corelib_BinNums_IntDef_Z_pos_div_eucl a2 b
        Zneg b2 ->
          case corelib_BinNums_IntDef_Z_pos_div_eucl a2 (Zpos b2) of
            Pair q r ->
              case r of
                Z0 ->
                  Pair (corelib_BinNums_IntDef_Z_opp q) Z0
                Zpos p ->
                  Pair (corelib_BinNums_IntDef_Z_opp (corelib_BinNums_IntDef_Z_add q (Zpos XH))) (corelib_BinNums_IntDef_Z_add b r)
                Zneg p ->
                  Pair (corelib_BinNums_IntDef_Z_opp (corelib_BinNums_IntDef_Z_add q (Zpos XH))) (corelib_BinNums_IntDef_Z_add b r)
    Zneg a2 ->
      case b of
        Z0 ->
          Pair Z0 a
        Zpos p ->
          case corelib_BinNums_IntDef_Z_pos_div_eucl a2 b of
            Pair q r ->
              case r of
                Z0 ->
                  Pair (corelib_BinNums_IntDef_Z_opp q) Z0
                Zpos p2 ->
                  Pair (corelib_BinNums_IntDef_Z_opp (corelib_BinNums_IntDef_Z_add q (Zpos XH))) (corelib_BinNums_IntDef_Z_sub b r)
                Zneg p2 ->
                  Pair (corelib_BinNums_IntDef_Z_opp (corelib_BinNums_IntDef_Z_add q (Zpos XH))) (corelib_BinNums_IntDef_Z_sub b r)
        Zneg b2 ->
          case corelib_BinNums_IntDef_Z_pos_div_eucl a2 (Zpos b2) of
            Pair q r ->
              Pair q (corelib_BinNums_IntDef_Z_opp r)

corelib_BinNums_IntDef_Z_div : Z -> Z -> Z
corelib_BinNums_IntDef_Z_div a b =
  case corelib_BinNums_IntDef_Z_div_eucl a b of
    Pair q x ->
      q

conCert_Examples_Escrow_Escrow_buyer : State -> Int
conCert_Examples_Escrow_Escrow_buyer s =
  case s of
    Build_state last_action next_step seller buyer seller_withdrawable buyer_withdrawable ->
      buyer

corelib_BinNums_PosDef_Pos_eqb : Positive -> Positive -> Bool
corelib_BinNums_PosDef_Pos_eqb p q =
  case p of
    XI p2 ->
      case q of
        XI q2 ->
          corelib_BinNums_PosDef_Pos_eqb p2 q2
        XO p0 ->
          False
        XH ->
          False
    XO p2 ->
      case q of
        XI p0 ->
          False
        XO q2 ->
          corelib_BinNums_PosDef_Pos_eqb p2 q2
        XH ->
          False
    XH ->
      case q of
        XI p0 ->
          False
        XO p0 ->
          False
        XH ->
          True

corelib_BinNums_IntDef_Z_eqb : Z -> Z -> Bool
corelib_BinNums_IntDef_Z_eqb x y =
  case x of
    Z0 ->
      case y of
        Z0 ->
          True
        Zpos p ->
          False
        Zneg p ->
          False
    Zpos p ->
      case y of
        Z0 ->
          False
        Zpos q ->
          corelib_BinNums_PosDef_Pos_eqb p q
        Zneg p0 ->
          False
    Zneg p ->
      case y of
        Z0 ->
          False
        Zpos p0 ->
          False
        Zneg q ->
          corelib_BinNums_PosDef_Pos_eqb p q

conCert_Examples_Escrow_Escrow_last_action : State -> Nat
conCert_Examples_Escrow_Escrow_last_action s =
  case s of
    Build_state last_action next_step seller buyer seller_withdrawable buyer_withdrawable ->
      last_action

conCert_Examples_Escrow_Escrow_seller : State -> Int
conCert_Examples_Escrow_Escrow_seller s =
  case s of
    Build_state last_action next_step seller buyer seller_withdrawable buyer_withdrawable ->
      seller

conCert_Examples_Escrow_Escrow_seller_withdrawable : State -> Z
conCert_Examples_Escrow_Escrow_seller_withdrawable s =
  case s of
    Build_state last_action next_step seller buyer seller_withdrawable buyer_withdrawable ->
      seller_withdrawable

conCert_Examples_Escrow_Escrow_buyer_withdrawable : State -> Z
conCert_Examples_Escrow_Escrow_buyer_withdrawable s =
  case s of
    Build_state last_action next_step seller buyer seller_withdrawable buyer_withdrawable ->
      buyer_withdrawable

conCert_Examples_Escrow_Escrow_set_State_last_action : (Nat -> Nat) -> State -> State
conCert_Examples_Escrow_Escrow_set_State_last_action f r =
  Build_state (f (conCert_Examples_Escrow_Escrow_last_action r)) (conCert_Examples_Escrow_Escrow_next_step r) (conCert_Examples_Escrow_Escrow_seller r) (conCert_Examples_Escrow_Escrow_buyer r) (conCert_Examples_Escrow_Escrow_seller_withdrawable r) (conCert_Examples_Escrow_Escrow_buyer_withdrawable r)

conCert_Examples_Escrow_Escrow_set_State_next_step : (NextStep -> NextStep) -> State -> State
conCert_Examples_Escrow_Escrow_set_State_next_step f r =
  Build_state (conCert_Examples_Escrow_Escrow_last_action r) (f (conCert_Examples_Escrow_Escrow_next_step r)) (conCert_Examples_Escrow_Escrow_seller r) (conCert_Examples_Escrow_Escrow_buyer r) (conCert_Examples_Escrow_Escrow_seller_withdrawable r) (conCert_Examples_Escrow_Escrow_buyer_withdrawable r)

conCert_Examples_Escrow_Escrow_set_State_seller_withdrawable : (Z -> Z) -> State -> State
conCert_Examples_Escrow_Escrow_set_State_seller_withdrawable f r =
  Build_state (conCert_Examples_Escrow_Escrow_last_action r) (conCert_Examples_Escrow_Escrow_next_step r) (conCert_Examples_Escrow_Escrow_seller r) (conCert_Examples_Escrow_Escrow_buyer r) (f (conCert_Examples_Escrow_Escrow_seller_withdrawable r)) (conCert_Examples_Escrow_Escrow_buyer_withdrawable r)

conCert_Examples_Escrow_Escrow_set_State_buyer_withdrawable : (Z -> Z) -> State -> State
conCert_Examples_Escrow_Escrow_set_State_buyer_withdrawable f r =
  Build_state (conCert_Examples_Escrow_Escrow_last_action r) (conCert_Examples_Escrow_Escrow_next_step r) (conCert_Examples_Escrow_Escrow_seller r) (conCert_Examples_Escrow_Escrow_buyer r) (conCert_Examples_Escrow_Escrow_seller_withdrawable r) (f (conCert_Examples_Escrow_Escrow_buyer_withdrawable r))

corelib_Init_Nat_leb : Nat -> Nat -> Bool
corelib_Init_Nat_leb n m =
  case n of
    O ->
      True
    S n2 ->
      case m of
        O ->
          False
        S m2 ->
          corelib_Init_Nat_leb n2 m2

corelib_Init_Nat_ltb : Nat -> Nat -> Bool
corelib_Init_Nat_ltb n m =
  corelib_Init_Nat_leb (S n) m

corelib_Init_Nat_add : Nat -> Nat -> Nat
corelib_Init_Nat_add n m =
  case n of
    O ->
      m
    S p ->
      S (corelib_Init_Nat_add p m)

stdlib_ZArith_BinIntDef_Z_gtb : Z -> Z -> Bool
stdlib_ZArith_BinIntDef_Z_gtb x y =
  case corelib_BinNums_IntDef_Z_compare x y of
    Eq ->
      False
    Lt ->
      False
    Gt ->
      True

corelib_Init_Datatypes_andb : Bool -> Bool -> Bool
corelib_Init_Datatypes_andb b1 b2 =
  case b1 of
    True ->
      b2
    False ->
      False

conCert_Examples_Escrow_Escrow_receive : ConCertChain -> ConCertCallContext -> State -> Option Msg -> Result (Prod State (List ConCertAction)) Error
conCert_Examples_Escrow_Escrow_receive chain ctx state msg =
  case msg of
    Some m ->
      case m of
        Commit_money ->
          case conCert_Examples_Escrow_Escrow_next_step state of
            Buyer_commit ->
              conCert_Execution_Monad_bind (Build_monad (\t t2 -> Ok t2) (\t u mt f -> case mt of
                                                                                         Ok t2 ->
                                                                                           f t2
                                                                                         Err e ->
                                                                                           Err e)) () () (conCert_Execution_ResultMonad_result_of_option (conCert_Examples_Escrow_Escrow_subAmountOption (ctx_contract_balance ctx) (ctx_amount ctx)) conCert_Examples_Escrow_Escrow_default_error) (\diff_ -> let
                                                                                                                                                                                                                                                                                                                 item_price =
                                                                                                                                                                                                                                                                                                                   corelib_BinNums_IntDef_Z_div diff_ (Zpos (XO XH))
                                                                                                                                                                                                                                                                                                               in
                                                                                                                                                                                                                                                                                                               let
                                                                                                                                                                                                                                                                                                                 expected =
                                                                                                                                                                                                                                                                                                                   corelib_BinNums_IntDef_Z_mul item_price (Zpos (XO XH))
                                                                                                                                                                                                                                                                                                               in
                                                                                                                                                                                                                                                                                                               conCert_Execution_Monad_bind (Build_monad (\t t2 -> Ok t2) (\t u mt f -> case mt of
                                                                                                                                                                                                                                                                                                                                                                                          Ok t2 ->
                                                                                                                                                                                                                                                                                                                                                                                            f t2
                                                                                                                                                                                                                                                                                                                                                                                          Err e ->
                                                                                                                                                                                                                                                                                                                                                                                            Err e)) () () (case Order.eq (ctx_from ctx) (conCert_Examples_Escrow_Escrow_buyer state) of
                                                                                                                                                                                                                                                                                                                                                                                                             True ->
                                                                                                                                                                                                                                                                                                                                                                                                               Ok Tt
                                                                                                                                                                                                                                                                                                                                                                                                             False ->
                                                                                                                                                                                                                                                                                                                                                                                                               Err conCert_Examples_Escrow_Escrow_default_error) (\x -> conCert_Execution_Monad_bind (Build_monad (\t t2 -> Ok t2) (\t u mt f -> case mt of
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   Ok t2 ->
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     f t2
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   Err e ->
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     Err e)) () () (case corelib_BinNums_IntDef_Z_eqb (ctx_amount ctx) expected of
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      True ->
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        Ok Tt
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      False ->
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        Err conCert_Examples_Escrow_Escrow_default_error) (\x2 -> Ok (Pair (conCert_Examples_Escrow_Escrow_set_State_last_action (\x3 -> current_slot chain) (conCert_Examples_Escrow_Escrow_set_State_next_step (\x3 -> Buyer_confirm) state)) Nil))))
            Buyer_confirm ->
              Err conCert_Examples_Escrow_Escrow_default_error
            Withdrawals ->
              Err conCert_Examples_Escrow_Escrow_default_error
            No_next_step ->
              Err conCert_Examples_Escrow_Escrow_default_error
        Confirm_item_received ->
          case conCert_Examples_Escrow_Escrow_next_step state of
            Buyer_commit ->
              Err conCert_Examples_Escrow_Escrow_default_error
            Buyer_confirm ->
              let
                item_price =
                  corelib_BinNums_IntDef_Z_div (ctx_contract_balance ctx) (Zpos (XO (XO XH)))
              in
              conCert_Execution_Monad_bind (Build_monad (\t t2 -> Ok t2) (\t u mt f -> case mt of
                                                                                         Ok t2 ->
                                                                                           f t2
                                                                                         Err e ->
                                                                                           Err e)) () () (case Order.eq (ctx_from ctx) (conCert_Examples_Escrow_Escrow_buyer state) of
                                                                                                            True ->
